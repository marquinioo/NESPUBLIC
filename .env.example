# Optional: POST endpoint for contact form (Formspree, custom API, etc.)
# CONTACT_FORM_ENDPOINT=https://formspree.io/f/your-form-id

# Optional: NES Charge app store links
# NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/...
# NEXT_PUBLIC_GOOGLE_PLAY_URL=https://play.google.com/store/apps/...

# Required for interactive charging map with markers (enable "Maps JavaScript API" in Google Cloud)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional: custom Google Maps embed URL (fallback when API key is not set)
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=...
